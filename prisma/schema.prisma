generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id Int @id @default(autoincrement())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  name  String  @unique
  brand String?
  unit  String

  minimumStock Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches ProductBatch[]
}

model Supplier {
  id Int @id @default(autoincrement())

  name    String
  company String?
  phone   String  @unique
  email   String?
  address String?

  openingDue Decimal @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches          ProductBatch[]
  purchases        Purchase[]
  supplierPayments SupplierPayment[]
  purchaseReturns  PurchaseReturn[]
}

model ProductBatch {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  purchasePrice Decimal @db.Decimal(12, 2)
  sellingPrice  Decimal @db.Decimal(12, 2)

  quantityPurchased Int
  quantityRemaining Int

  manufactureDate DateTime?
  expiryDate      DateTime?

  purchaseDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  saleReturnItems     SaleReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]

  damages Damage[]

  stockAdjustments StockAdjustment[]
}

model Purchase {
  id Int @id @default(autoincrement())

  purchaseNo String @unique

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  purchaseDate DateTime

  totalAmount Decimal @db.Decimal(12, 2)
  paidAmount  Decimal @db.Decimal(12, 2)
  dueAmount   Decimal @db.Decimal(12, 2)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseItem[]

  purchaseReturns PurchaseReturn[]
}

model PurchaseItem {
  id Int @id @default(autoincrement())

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id])

  quantity Int

  buyPrice Decimal @db.Decimal(12, 2)

  totalPrice Decimal @db.Decimal(12, 2)

  purchaseReturnItems PurchaseReturnItem[]
}

model Customer {
  id Int @id @default(autoincrement())

  name String

  phone String @unique

  address String?

  openingDue Decimal @default(0) @db.Decimal(12, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  payments CustomerPayment[]

  saleReturns SaleReturn[]
}

model Sale {
  id Int @id @default(autoincrement())

  invoiceNo String @unique

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  saleDate DateTime

  totalAmount Decimal @db.Decimal(12, 2)

  discount Decimal @default(0) @db.Decimal(12, 2)

  paidAmount Decimal @db.Decimal(12, 2)

  dueAmount Decimal @db.Decimal(12, 2)

  note String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  items SaleItem[]

  payments CustomerPayment[]

  saleReturns SaleReturn[]
}

model SaleItem {
  id Int @id @default(autoincrement())

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id])

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id])

  quantity Int

  buyPrice Decimal @db.Decimal(12, 2)

  sellPrice Decimal @db.Decimal(12, 2)

  totalPrice Decimal @db.Decimal(12, 2)

  profit Decimal @db.Decimal(12, 2)

  saleReturnItems SaleReturnItem[]
}

model CustomerPayment {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  paymentMethod String

  paymentDate DateTime

  note String?

  createdAt DateTime @default(now())
}

model ExpenseCategory {
  id Int @id @default(autoincrement())

  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]
}

model Expense {
  id Int @id @default(autoincrement())

  categoryId Int
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  expenseDate DateTime

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CashBook {
  id Int @id @default(autoincrement())

  transactionDate DateTime

  type String

  amount Decimal @db.Decimal(12, 2)

  description String?

  referenceType String?

  referenceId Int?

  createdAt DateTime @default(now())
}

model SupplierPayment {
  id Int @id @default(autoincrement())

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  paymentDate DateTime

  paymentMethod String

  note String?

  createdAt DateTime @default(now())
}

model Damage {
  id Int @id @default(autoincrement())

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id])

  quantity Int

  reason String?

  damageDate DateTime

  createdAt DateTime @default(now())
}

model StockAdjustment {
  id Int @id @default(autoincrement())

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id])

  previousStock Int

  newStock Int

  reason String?

  adjustmentDate DateTime

  createdAt DateTime @default(now())
}

model ActivityLog {
  id Int @id @default(autoincrement())

  action String

  module String

  referenceId Int?

  description String?

  createdAt DateTime @default(now())
}

model User {
  id Int @id @default(autoincrement())

  name String

  username String @unique

  password String

  role String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Settings {
  id Int @id @default(autoincrement())

  shopName String

  shopAddress String?

  shopPhone String?

  currency String @default("BDT")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model SaleReturn {
  id Int @id @default(autoincrement())

  saleId Int
  sale   Sale @relation(fields: [saleId], references: [id])

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  returnDate DateTime

  totalAmount Decimal @db.Decimal(12, 2)

  cashReturned Decimal @default(0) @db.Decimal(12, 2)

  adjustedDue Decimal @default(0) @db.Decimal(12, 2)

  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items SaleReturnItem[]
}

model SaleReturnItem {
  id Int @id @default(autoincrement())

  saleReturnId Int
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])

  saleItemId Int
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id])

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id])

  quantity Int

  buyPrice Decimal @db.Decimal(12, 2)

  sellPrice Decimal @db.Decimal(12, 2)

  totalPrice Decimal @db.Decimal(12, 2)

  profitReduced Decimal @db.Decimal(12, 2)
}

model PurchaseReturn {
  id Int @id @default(autoincrement())

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  returnDate DateTime

  totalAmount Decimal @db.Decimal(12, 2)

  cashReceived Decimal @default(0) @db.Decimal(12, 2)

  adjustedDue Decimal @default(0) @db.Decimal(12, 2)

  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id Int @id @default(autoincrement())

  purchaseReturnId Int
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])

  purchaseItemId Int
  purchaseItem   PurchaseItem @relation(fields: [purchaseItemId], references: [id])

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id])

  quantity Int

  buyPrice Decimal @db.Decimal(12, 2)

  totalPrice Decimal @db.Decimal(12, 2)
}
